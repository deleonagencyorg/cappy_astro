---
/**
 * PromosSkeletonSectionPlaceholder.astro
 * Placeholder que muestra mientras se cargan promos (evita flash blanco en navegación)
 */
---

<section class="mt-10 md:mt-14">
  <div class="flex items-start justify-between gap-6 mb-6">
    <div class="h-12 md:h-16 w-48 bg-gray-300 rounded-lg"></div>
  </div>
  
  <!-- Mobile carousel skeleton -->
  <div class="mt-6 md:hidden flex gap-4 overflow-x-auto pb-2">
    {[...Array(3)].map(() => (
      <div class="snap-start shrink-0 w-[280px] rounded-[28px] bg-gray-300 h-[340px]"></div>
    ))}
  </div>
  
  <!-- Desktop grid skeleton -->
  <div class="hidden md:grid mt-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {[...Array(6)].map(() => (
      <div class="rounded-[28px] bg-gray-300 h-[420px]"></div>
    ))}
  </div>
</section>
